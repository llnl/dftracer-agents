# ===== LLM endpoint — OpenAI-compatible =====
# Option A: set these directly
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Goose uses the OpenAI-compatible provider with OPENAI_HOST/OPENAI_BASE_PATH.
# The launchers derive these automatically from OPENAI_BASE_URL or LIVAI_BASE_URL.
# GOOSE_PROVIDER=openai
# GOOSE_MODEL=${OPENAI_MODEL}

# Option B: LLNL LIVAI (launchers map these to both OPENAI_* and Goose settings)
LIVAI_BASE_URL=https://livai-api.llnl.gov/v1
LIVAI_MODEL=gpt-5.4
LIVAI_API_KEY=

# ===== DFTracer defaults =====
DFTRACER_ENABLE=1
DFTRACER_LOG_FILE=./traces/dftrace
DFTRACER_DATA_DIR=$PWD

# ===== Offline cargo cache =====
CARGO_HOME=/usr/workspace/iopp/cargo_cache
